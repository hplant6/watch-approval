# Copy to .env and fill in. (WATCH_APPROVAL_APNS_KEY + TOKENS_FILE are set by compose.)

WATCH_APPROVAL_APNS_KEY_ID=7Z385599QY
WATCH_APPROVAL_APNS_TEAM_ID=R5T9D4ATJQ
WATCH_APPROVAL_APNS_TOPIC=com.cathode.approvals
# Dev-signed app → APNs sandbox. Set to 0 only for a production/TestFlight build.
WATCH_APPROVAL_APNS_SANDBOX=1

# Strongly recommended once this is reachable beyond your LAN (e.g. via Tailscale or a
# tunnel): a long random string. Cathode and the phone app must send the same value.
WATCH_APPROVAL_SECRET=
